rules_version = '2';

// All reads/writes go through the Cloud Function (firebase-admin SDK,
// which bypasses these rules) — the browser never talks to Firestore
// directly, so client access is locked down entirely.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
